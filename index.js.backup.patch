console.log("DEBUG: Token Telegram:", process.env.TELEGRAM_TOKEN ? "DEFINIDO" : "VAZIO");
const { Telegraf } = require('telegraf');
const { Octokit } = require('@octokit/rest');

// Configurações
const BOT_TOKEN = process.env.TELEGRAM_TOKEN;
const GITHUB_TOKEN = process.env.GITHUB_TOKEN;
const REPO_OWNER = process.env.REPO_OWNER;
const REPO_NAME = process.env.REPO_NAME;

const bot = new Telegraf(BOT_TOKEN);
const octokit = new Octokit({ auth: GITHUB_TOKEN });

// Função de execução (polling robusto)
async function triggerAndWait(ctx, code) {
    try {
        // Sanitização simples de múltiplas linhas
        const sanitizedCode = code.replace(/\\/g, '\\\\').replace(/"/g, '\\"');
        
        // Disparar Workflow
        const run = await octokit.rest.actions.createWorkflowDispatch({
            owner: REPO_OWNER,
            repo: REPO_NAME,
            workflow_id: 'code_executor.yml',
            ref: 'main',
            inputs: { code: sanitizedCode }
        });

        ctx.reply("✅ Workflow disparado, aguardando resultado...");

        // Polling (96 tentativas x 5s = 8 minutos de timeout total)
        for (let i = 0; i < 96; i++) {
            await new Promise(r => setTimeout(r, 5000));
            // Lógica de verificação de status (exemplo simplificado)
            // Aqui você deve inserir a chamada para listar os runs e pegar o resultado
            // ... (certifique-se que o restante da lógica de polling está aqui)
        }
    } catch (err) {
        ctx.reply(`❌ Erro no trigger: ${err.message}`);
    }
}

// Handler do comando /exec
bot.command('exec', async (ctx) => {
    const code = ctx.message.text.split(' ').slice(1).join(' ');
    if (!code) return ctx.reply("Uso: /exec <code>");
    await triggerAndWait(ctx, code);
});

bot.launch();
process.once('SIGINT', () => bot.stop('SIGINT'));
process.once('SIGTERM', () => bot.stop('SIGTERM'));
