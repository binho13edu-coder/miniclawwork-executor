const { Telegraf } = require('telegraf');
const axios = require('axios');

const config = {
    token: process.env.TELEGRAM_TOKEN,
    openrouter: process.env.OPENROUTER_API_KEY,
    groq: process.env.GROQ_API_KEY,
    admin: parseInt(process.env.OWNER_ID)
};

const bot = new Telegraf(config.token);

async function generate(prompt) {
    try {
        console.log("Tentando OpenRouter...");
        const res = await axios.post('https://openrouter.ai/api/v1/chat/completions', {
            model: "meta-llama/llama-3-8b-instruct",
            messages: [{role: "user", content: prompt}]
        }, { headers: { Authorization: `Bearer ${config.openrouter}` }, timeout: 10000 });
        return res.data.choices[0].message.content;
    } catch (e) {
        console.error("Erro OpenRouter:", e.response?.status || e.message);
        console.log("Tentando Groq...");
        const res = await axios.post('https://api.groq.com/openai/v1/chat/completions', {
            model: "llama3-8b-8192",
            messages: [{role: "user", content: prompt}]
        }, { headers: { Authorization: `Bearer ${config.groq}` }, timeout: 10000 });
        return res.data.choices[0].message.content;
    }
}

// 1. COMANDOS PRIMEIRO
bot.command("exec", async (ctx) => {
  if (ctx.from.id !== config.admin) return;
  const code = ctx.message.text.replace("/exec", "").trim();
  if (!code) return ctx.reply("Uso: /exec <código>");
  await ctx.reply("⚙️ Executando...");
  try {
    const res = await axios.get("http://localhost:3001/ask", {
      params: { q: code },
      timeout: 30000
    });
    await ctx.reply("✅ Resultado:\n" + res.data);
  } catch (e) {
    await ctx.reply("❌ Erro: " + e.message);
  }
});

// 2. MIDDLEWARE DE TEXTO DEPOIS
bot.on('text', async (ctx) => {
    if (ctx.message.text.startsWith('/')) return;
    if (ctx.from.id !== config.admin) return;

    const wait = await ctx.reply("💬...");
    try {
        const reply = await generate(ctx.message.text);
        await ctx.telegram.editMessageText(ctx.chat.id, wait.message_id, null, reply);
    } catch (e) {
        const status = e.response?.status || "Erro de Conexão";
        console.error("Erro Final:", e.message);
        await ctx.telegram.editMessageText(ctx.chat.id, wait.message_id, null, `❌ Falha (Status: ${status}).`);
    }
});

// 3. HTTP SERVER
const http = require('http');
const url = require('url');

http.createServer(async (req, res) => {
  if (req.url.startsWith("/ask")) {
    const parsed = url.parse(req.url, true);
    const query = parsed.query.q;
    if (!query) { res.writeHead(400); return res.end("Missing query"); }
    try {
      const result = await generate(query);
      res.writeHead(200);
      return res.end(result);
    } catch (e) { res.writeHead(500); return res.end("Erro: " + e.message); }
  } else if (req.url === "/health") {
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ status: 'ok', uptime: process.uptime() }));
  } else { res.writeHead(404); res.end(); }
}).listen(3001, () => console.log("🌐 HTTP Server rodando na porta 3001"));

// 4. LAUNCH
bot.telegram.setMyCommands([{ command: "exec", description: "Executar código" }]);
bot.launch().then(() => console.log("🚀 MiniClawwork v1.1 Online"));

// Enable graceful stop
process.once('SIGINT', () => bot.stop('SIGINT'));
process.once('SIGTERM', () => bot.stop('SIGTERM'));

// === EXECUTOR VIA GITHUB ACTIONS ===
const { Octokit } = require('@octokit/rest');
const AdmZip = require('adm-zip');
const { v4: uuidv4 } = require('uuid');

const octokit = new Octokit({ auth: process.env.GITHUB_TOKEN });
const REPO_OWNER = process.env.REPO_OWNER || 'binho13edu-coder';
const REPO_NAME = process.env.REPO_NAME || 'miniclawwork-executor';
const sleep = ms => new Promise(r => setTimeout(r, ms));

async function triggerAndWait(code) {
  const taskId = uuidv4();
  const codeB64 = Buffer.from(code).toString('base64');

  await octokit.repos.createDispatchEvent({
    owner: REPO_OWNER,
    repo: REPO_NAME,
    event_type: 'run-python',
    client_payload: { code: codeB64, task_id: taskId }
  });

  await sleep(8000);

  for (let i = 0; i < 36; i++) {
    const { data: runs } = await octokit.actions.listWorkflowRunsForRepo({
      owner: REPO_OWNER,
      repo: REPO_NAME,
      per_page: 10
    });
    const run = runs[0];
    if (!run || run.status !== 'completed') { await sleep(5000); continue; }

    const { data: artifacts } = await octokit.actions.listWorkflowRunArtifacts({
      owner: REPO_OWNER,
      repo: REPO_NAME,
      run_id: run.id
    });
    const artifact = artifacts.find(a => a.name.includes(taskId));
    if (!artifact) { await sleep(5000); continue; }

    const { data: zipData } = await octokit.actions.downloadArtifact({
      owner: REPO_OWNER,
      repo: REPO_NAME,
      artifact_id: artifact.id,
      archive_format: 'zip'
    });
    const zip = new AdmZip(Buffer.from(zipData));
    const entry = zip.getEntry('output.txt');
    if (!entry) return '❌ output.txt não encontrado';
    return zip.readAsText(entry);
  }
  return '⏱️ Timeout esperando resultado';
}

// Sobrescreve o handler /exec
bot.command('exec', async (ctx) => {
  if (process.env.OWNER_ID && ctx.from.id !== parseInt(process.env.OWNER_ID))
    return ctx.reply('⛔ Acesso negado.');
  const code = ctx.message.text.replace('/exec', '').trim();
  if (!code) return ctx.reply('Uso: /exec <código python>');
  await ctx.reply('⏳ Executando...');
  try {
    const result = await triggerAndWait(code);
    await ctx.reply(`✅ Resultado:\n${result}`);
  } catch (err) {
    await ctx.reply(`❌ Erro: ${err.message}`);
  }
});
